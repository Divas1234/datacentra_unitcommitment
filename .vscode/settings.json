{
    "editor.wordWrapColumn": 150,
    "editor.wordWrap": "wordWrapColumn",
    "editor.fontFamily": "Roboto Medium, Dubai, Chaparral Pro, Calisto, Helvetic, SF Pro, Fira Code, Geist Mono, JetBrains Mono, Maple Mono, Maison Mono, Droid Sans Mono, Apercu Mono Pro, Menlo, Monaco, 'Courier New', monospace",
    "workbench.editor.highlightModifiedTabs": true,
    "terminal.integrated.fontLigatures.enabled": true,
    "CodeGPT.apiKey": "CodeGPT Plus Beta",
    "bookmarks.sideBar.expanded": true,
    "spellright.language": [
        "en"
    ],
    "spellright.documentTypes": [
        "markdown",
        "latex",
        "plaintext"
    ],
    "editor.fontSize": 18,
    "cSpell.words": [
        "distributionally",
        "DVFS",
        "microgrid",
        "microgrids"
    ],
    "github.copilot.chat.agent.thinkingTool": true,
    "github.copilot.chat.codesearch.enabled": true,
    "window.autoDetectColorScheme": true
}